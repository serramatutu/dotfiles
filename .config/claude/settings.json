{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  },
  "attribution": {
    "commit": "Generated with the help of AI.",
    "pr": ""
  },
  "model": "us.anthropic.claude-sonnet-4-5-20250929-v1:0",
  "allowedHttpHookUrls": [],
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true
  },
  "editorMode": "vim",
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "permissions": {
    "allow": [
      "Bash(cut:*)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git rebase:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(sed:*)",
      "Bash(wait:*)",
      "Bash(docker compoose:*)"
    ]
  }
}
