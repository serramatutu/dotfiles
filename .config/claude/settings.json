{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  },
  "attribution": {
    "commit": "Generated with the help of AI.",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(cut:*)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git log:*)",
      "Bash(git rebase:*)",
      "Bash(git show:*)",
      "Bash(git status:*)",
      "Bash(grep:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(sed:*)",
      "Bash(wait:*)",
      "Bash(docker compoose:*)"
    ]
  },
  "model": "sonnet",
  "allowedHttpHookUrls": [],
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "sandbox": {
    "enabled": true,
    "failIfUnavailable": true
  },
  "editorMode": "vim",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  }
}
